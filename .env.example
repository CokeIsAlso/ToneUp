# 이 파일을 .env 로 복사한 뒤 실제 값으로 채우세요.
#   복사:  copy .env.example .env   (Windows)
# .env 는 .gitignore 에 등록되어 깃에 올라가지 않습니다.

# OpenAI API 키 (AI 코칭 기능에 사용)
OPENAI_API_KEY=sk-여기에_본인_키_입력

# AI 코칭 모델 (선택)
OPENAI_MODEL=gpt-4o-mini

# 세션 서명 키 (배포 시 반드시 임의의 긴 문자열로 변경)
# TONEUP_SECRET_KEY=change-this-to-a-random-secret

# 기타 선택 설정
# TONEUP_WHISPER_MODEL=base
# FFMPEG_BIN=ffmpeg
# FLASK_DEBUG=1
